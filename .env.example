# Copy the values you need into your shell environment before running:
#   export RPC_ENDPOINT=...  GEYSER_GRPC_URL=...  WALLET_PRIVATE_KEY=...
# Never commit a real key, and only ever use a dedicated, low-value wallet.

# DEMO mode shows the dashboard with simulated data — no wallet/RPC/Geyser needed:
#   DEMO=true go run ./cmd
DEMO=false

# Primary Solana RPC endpoint (a low-latency provider is recommended for sniping).
RPC_ENDPOINT=http://127.0.0.1:8899

# Geyser gRPC streaming endpoint, host:port. Most public RPCs do not expose Geyser.
GEYSER_GRPC_URL=127.0.0.1:10000

# Base58-encoded wallet secret key. Treat as disposable.
WALLET_PRIVATE_KEY=your_base58_private_key_here

# --- Exit / safety controls ---
# DRY_RUN defaults to true: transactions are BUILT but never submitted.
# Set to false ONLY when you intend to trade real funds.
DRY_RUN=true

# Auto take-profit / stop-loss thresholds (percent).
TAKE_PROFIT_PCT=50
STOP_LOSS_PCT=40

# How often (seconds) the exit monitor re-checks open-position prices.
POLL_SECONDS=3
